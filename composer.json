{
    "name": "darryldias/sqlite-db-wp",
    "description": "Modern SQLite DB for WordPress — A secure, PHP 8.x-optimized SQLite drop-in database driver",
    "type": "wordpress-dropin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Darryl Dias",
            "role": "Developer"
        },
        {
            "name": "Evan Mattson",
            "role": "Original Developer"
        },
        {
            "name": "Kojima Toshiyasu",
            "homepage": "https://profiles.wordpress.org/kjmtsh",
            "role": "Author of SQLite Integration"
        }
    ],
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/src"
        }
    },
    "require": {
        "php": ">=8.0",
        "ext-PDO": "*",
        "composer/installers": "^1.0 || ^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^5 || ^6 || ^7 || ^8 || ^9",
        "roots/wordpress": "^6",
        "wp-cli/core-command": "^2",
        "wp-phpunit/wp-phpunit": "^6",
        "yoast/phpunit-polyfills": "^1",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "allow-plugins": {
            "roots/wordpress-core-installer": true,
            "composer/installers": true
        }
    }
}
